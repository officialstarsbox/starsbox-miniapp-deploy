# ---------------------------------------------------------------------------
# Хелперы сумм
# ---------------------------------------------------------------------------

def parse_amounts(body: InitiateReq) -> tuple[int, str]:
    """
    Возвращает: (amount_minor:int, amount_str:'xx.xx')
    """
    if body.amount_str:
        amt = Decimal(str(body.amount_str).replace(",", ".")).quantize(Decimal("0.01"), rounding=ROUND_DOWN)
        minor = int((amt * 100).to_integral_value(rounding=ROUND_DOWN))
        if minor <= 0:
            raise HTTPException(422, "bad amount_str")
        return minor, f"{amt:.2f}"

    if body.amount_minor is not None:
        minor = int(body.amount_minor)
        if minor <= 0:
            raise HTTPException(422, "bad amount_minor")
        s = (Decimal(minor) / Decimal(100)).quantize(Decimal("0.00"), rounding=ROUND_DOWN)
        return minor, f"{s:.2f}"

    if body.amount is not None:
        rub = Decimal(int(body.amount)).quantize(Decimal("0"), rounding=ROUND_DOWN)
        minor = int((rub * 100).to_integral_value(rounding=ROUND_DOWN))
        return minor, f"{rub:.2f}"

    raise HTTPException(422, "amount_str or amount_minor or amount is required")

